# Normalize line endings to LF for text files, except Windows scripts.
* text=auto

*.js    text eol=lf
*.ts    text eol=lf
*.vue   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.java  text eol=lf
*.groovy text eol=lf
*.xml   text eol=lf
*.properties text eol=lf
*.sql   text eol=lf

*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
